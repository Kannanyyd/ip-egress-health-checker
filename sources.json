  "script_repositories": [
    {
      "name": "xykt/IPQuality",
      "url": "https://github.com/xykt/IPQuality",
      "run": "bash <(curl -Ls https://IP.Check.Place) -p -f -j",
      "category": ["ip_purity", "risk", "dnsbl", "mail", "media_ai_unlock"],
      "automation": "script_json",
      "notes": "主力纯净度脚本。支持 -x 代理、-j JSON、-o 输出文件。"
    },
    {
      "name": "adsorgcn/vpscheck",
      "url": "https://github.com/adsorgcn/vpscheck",
      "run": "bash <(curl -sL https://raw.githubusercontent.com/adsorgcn/vpscheck/main/vpscheck.sh) -r 1",
      "category": ["vps_check", "media_unlock", "ai_unlock", "route", "benchmark"],
      "automation": "script_text",
      "notes": "中文圈一键验 VPS，偏综合验货；IP 风险深度不如 IPQuality。"
    },
    {
      "name": "lmc999/RegionRestrictionCheck",
      "url": "https://github.com/lmc999/RegionRestrictionCheck",
      "run": "bash <(curl -L -s check.unlock.media)",
      "category": ["media_unlock", "region_restriction"],
      "automation": "script_text",
      "notes": "check.unlock.media 是常用入口。强项是流媒体区域解锁。"
    },
    {
      "name": "oneclickvirt/ecs",
      "url": "https://github.com/oneclickvirt/ecs",
      "category": ["vps_check", "route", "benchmark", "ip_quality"],
      "automation": "script_text",
      "notes": "VPS 融合怪 Go 版，适合机器/线路/性能综合体检。"
    },
    {
      "name": "spiritLHLS/ecs",
      "url": "https://github.com/spiritLHLS/ecs",
      "category": ["vps_check", "route", "benchmark", "ip_quality"],
      "automation": "script_text",
      "notes": "VPS 融合怪 Shell 版。"
    },
    {
      "name": "snailyp/ip-checker",
